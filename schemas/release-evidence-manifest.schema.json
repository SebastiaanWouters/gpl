{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://geopool.dev/schemas/release-evidence-manifest.schema.json",
  "title": "GPL Release Evidence Manifest",
  "type": "object",
  "required": [
    "manifest_version",
    "items"
  ],
  "additionalProperties": false,
  "properties": {
    "manifest_version": {
      "type": "string",
      "pattern": "^1\\.0$"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "checklist_id",
          "artifact_path",
          "artifact_type",
          "status"
        ],
        "additionalProperties": false,
        "properties": {
          "checklist_id": {
            "type": "string",
            "minLength": 1
          },
          "artifact_path": {
            "type": "string",
            "minLength": 1
          },
          "artifact_type": {
            "type": "string",
            "enum": [
              "doc",
              "manifest",
              "fixture",
              "test",
              "benchmark",
              "review"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "placeholder",
              "planned",
              "landed"
            ]
          },
          "spec_refs": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": []
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  }
}
